<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ligg.flowclient.mapper.ForumCommentMapper">

    <!-- 根据一级评论 id 列表，查询 parent_id 命中该列表的直接子回复。 -->
    <select id="selectRepliesByParentIds" resultType="com.ligg.flowclient.module.entity.ForumCommentEntity">
        SELECT id,
               user_id,
               parent_id,
               content,
               image_url,
               nickname,
               avatar_url,
               like_count,
               ip_address,
               create_time
        FROM forum_comment
        WHERE parent_id IN
        <foreach collection="parentIds" item="pid" open="(" separator="," close=")">
            #{pid}
        </foreach>
        ORDER BY create_time ASC
    </select>
</mapper>
